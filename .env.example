# =============================================================================
# Personal AI Voice Diary — environment template
# Copy to .env and fill in real values. Never commit .env to git.
# =============================================================================

# ---- LLM (DeepSeek, OpenAI-compatible) -------------------------------------
# Get your key from https://platform.deepseek.com/  (sign up → API Keys)
DEEPSEEK_API_KEY=sk-replace-with-your-real-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# ---- App --------------------------------------------------------------------
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

# ---- Data -------------------------------------------------------------------
# Where SQLite, ChromaDB, audio files live. Relative to project root is fine.
DATA_DIR=./data
